    VAR bool isConnected:=FALSE;
    VAR bool initDone:=FALSE;
    VAR string recvMsg:="";
    VAR bool ABC:=FALSE;
    VAR bool SEND:=FALSE;
    VAR bool caseth:=FALSE;

    PROC main()

        isConnected:=TRUE;
        recvMsg:="Reaady";
        WHILE isConnected DO
            IF NOT initDone THEN
                IF recvMsg="CHECK" THEN
                    p_home_R;
                    WaitSyncTask\InPos,sync1,task_list;
                    p_check_BFR_R;
                    WaitTime 1;
                    WaitSyncTask\InPos,sync6,task_list;
                    ! Nhung lenh khoi tao chi chay 1 lan
                    WaitTime 0.5;
                    IF NOT caseth THEN
                        !                        open_gripper_R;
                        !                        AccSet 100,100,\FinePointRamp:=100;
                        !                        MoveL waitpoint,v800,z5,Servo\WObj:=wobj0;
                        !                        WaitSyncTask\InPos,sync93,task_list;
                        caseth:=TRUE;
                    ENDIF
                    initDone:=TRUE;
                    ABC:=TRUE;
                ENDIF
            ENDIF
            IF caseth THEN
                SEND:=TRUE;
                p_lib_rotate_R;
                ! Lop nhan va xu ly lenh xoay tu Visual Studio
            ENDIF
        ENDWHILE
    ENDPROC
